rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function validProfileData(data) {
      return data.keys().hasOnly(['uuid', 'display_name', 'created_at'])
        && data.uuid is string
        && data.uuid == request.auth.uid
        && data.display_name is string
        && data.display_name.size() > 0
        && data.display_name.size() <= 40
        && (!('created_at' in data) || data.created_at is string || data.created_at is timestamp);
    }

    match /profiles/{profileId} {
      allow get, list: if signedIn() && resource.data.uuid == request.auth.uid;
      allow create: if signedIn() && validProfileData(request.resource.data);
      allow update: if signedIn()
        && resource.data.uuid == request.auth.uid
        && request.resource.data.uuid == resource.data.uuid
        && validProfileData(request.resource.data);
      allow delete: if signedIn() && resource.data.uuid == request.auth.uid;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
